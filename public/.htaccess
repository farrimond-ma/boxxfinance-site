# ── Block PHP execution ───────────────────────────────────────────────────────
# This site is a React SPA — no PHP should ever execute.
# If an attacker uploads a PHP file, this prevents it from running.
<FilesMatch "\.php$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType application/json .json
</IfModule>

# ── Caching strategy ─────────────────────────────────────────────────────────
# index.html must never be cached — it references hashed asset filenames
# that change on every deploy. Stale caches = blank page.
<IfModule mod_headers.c>
  # No caching for HTML files (especially index.html)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  # Long-lived cache for hashed assets (JS/CSS filenames change on rebuild)
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # JSON (per-article content files, system-status) — filenames are stable but
  # contents change on publish, so always revalidate (cheap 304s via Last-Modified)
  <FilesMatch "\.(json)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
  # XML (sitemap, RSS) — regenerated on every publish; a proxy-cached stale
  # sitemap misleads Google right after deploys, so always revalidate
  <FilesMatch "\.(xml)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
  # Moderate cache for images and fonts
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

# One page = one URL. Prerendered pages live as directories (insights/slug/index.html)
# or flat files (locations/slug.html); both are served INTERNALLY at the clean,
# canonical, no-slash URL — never via an external redirect. Google Search Console
# was reporting 66 "Page with redirect" + duplicate-canonical errors because
# Apache's DirectorySlash 301'd every sitemap URL to its slash variant.
Options -Indexes -MultiViews
<IfModule mod_dir.c>
  DirectorySlash Off
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── www → non-www canonical redirect ───────────────────────────────────────
  RewriteCond %{HTTP_HOST} ^www\.boxxfinance\.co\.uk [NC]
  RewriteRule ^(.*)$ https://boxxfinance.co.uk/$1 [R=301,L]

  # ── Retired pages → closest living page (SOFT 404 fixes, 2026-07-15) ───────
  # This is a React SPA: any unknown URL still serves index.html with HTTP 200,
  # React renders the NotFound component, and Google logs a SOFT 404 because it
  # never receives a real 404 status. Explicit 301s are the only fix. Each rule
  # below was confirmed against a GSC Soft 404 export.
  #
  # Retired posts — these slugs no longer exist in blogPosts.json. Matched on
  # both /advice/ and /insights/ because Google has crawled both forms.
  RewriteRule ^(?:advice|insights)/understanding-asset-finance-growth/?$ /funding-solutions/asset-finance [R=301,L]
  RewriteRule ^(?:advice|insights)/role-commercial-finance-broker/?$ /funding-solutions [R=301,L]
  RewriteRule ^(?:advice|insights)/commercial-finance-smes-right-funding-structure/?$ /funding-solutions [R=301,L]
  RewriteRule ^(?:advice|insights)/understanding-loan-costs-mistakes-to-avoid/?$ /insights/bridging-loan-costs-breakdown [R=301,L]

  # Bare /advice index — the /advice/(.+) rule below requires a suffix, so this fell through to a soft 404.
  RewriteRule ^advice/?$ /insights [R=301,L]

  # Old "-in-" location slug scheme (bridging-loans-in-london → bridging-loans-london).
  # Safe: no current slug contains "-in-" (verified against locationPages.json).
  RewriteRule ^locations/bridging-loans-in-(.+)$ /locations/bridging-loans-$1 [R=301,L]

  # Service pages that were linked by the content engine but never built.
  # The engine's maps now point at these real pages; this catches what Google already crawled.
  RewriteRule ^funding-solutions/cashflow-finance/?$ /funding-solutions/working-capital [R=301,L]
  RewriteRule ^funding-solutions/mezzanine-finance/?$ /funding-solutions/structured-finance [R=301,L]

  # /about-us was never a route — About lives on the homepage. NE preserves the #.
  RewriteRule ^about-us/?$ /#about [R=301,NE,L]

  # ── Legacy URL redirects ────────────────────────────────────────────────────
  # Old /advice/* posts moved to /insights/*
  RewriteRule ^advice/(.+)$ /insights/$1 [R=301,L]

  # Location pages retargeted to the higher-volume "bridging loans" term (2026-07)
  RewriteRule ^locations/bridging-finance-(.+)$ /locations/bridging-loans-$1 [R=301,L]

  # Bridging service page + enquiry form renamed to "bridging loans" (2026-07)
  RewriteRule ^funding-solutions/bridging-finance$ /funding-solutions/bridging-loans [R=301,L]
  RewriteRule ^chat-about-funding/bridging-finance$ /chat-about-funding/bridging-loans [R=301,L]

  # Blog posts retitled to "bridging loans" (2026-07)
  RewriteRule ^insights/bridging-finance-for-hmo-conversion$ /insights/bridging-loans-for-hmo-conversion [R=301,L]

  # Old application form
  RewriteRule ^start-application/.*$ /chat-about-funding [R=301,L]

  # ── /page.html (as requested by the client) → /page ─────────────────────────
  # Guard on THE_REQUEST (the original request line, unchanged by internal
  # rewrites) so this never loops with the internal .html rewrite below.
  RewriteCond %{THE_REQUEST} !\s/[^?\s]*index\.html
  RewriteCond %{THE_REQUEST} \s/([^?\s]+)\.html[\s?]
  RewriteRule ^ /%1 [R=301,L]

  # ── /page.htm → /page ──────────────────────────────────────────────────────
  # The .html rule above cannot match .htm (it requires the trailing "l"), so
  # .htm URLs fell through to the SPA and logged as soft 404s. Distinct pattern,
  # so this never double-fires with the .html rule.
  RewriteCond %{THE_REQUEST} \s/([^?\s]+)\.htm[\s?]
  RewriteRule ^ /%1 [R=301,L]

  # ── Remove trailing slashes (root excluded by the pattern) ──────────────────
  # Applies to directories too — DirectorySlash Off stops Apache re-adding it,
  # and the internal rewrite below serves the directory's index.html instead.
  RewriteCond %{THE_REQUEST} \s/[^?\s]+/[\s?]
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # ── Serve prerendered directory pages without redirect ──────────────────────
  # /insights/slug → insights/slug/index.html (200, no slash added)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+)$ $1/index.html [L]

  # ── Serve prerendered flat pages (e.g. /locations/slug → locations/slug.html) ──
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
  RewriteRule ^(.+[^/])$ $1.html [L]

  # ── SPA routing: serve index.html for all non-file, non-dir requests ────────
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule ^ index.html [L]
</IfModule>
